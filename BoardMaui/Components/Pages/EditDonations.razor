@using System.Text.Json
@using BoardMaui
@using BoardMaui.Extensions
@using BoardMaui.Models

@inject DatabaseUtility DatabaseUtility
@page "/editdonations"

<style>
    * {
        opacity: 1 !important;
    }
</style>
<form class="container my-4">
    <div class="content-card shadow-sm">
        <div class="card-body">
            <div class="row">

                <!-- עורך תרומות -->
                <div class="col-md-4 mb-3">
                    <h5 class="card-title fw-bold">עורך תרומות</h5>
                    <hr />

                    <div class="mb-3">
                        <label class="form-label">שם:</label>
                        <input type="text" class="form-control" @bind="name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">תרומה:</label>
                        <input type="number" class="form-control" @bind="donation" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">שולם:</label>
                        <input type="number" class="form-control" @bind="paid" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">נשאר לתשלום:</label>
                        <div class="form-control bg-light">@((donation - paid))</div>
                    </div>

                    <button type="reset" class="btn btn-primary w-100" @onclick="Add">הוסף</button>
                </div>

                <!-- רשימת תרומות -->
                <div class="col-md-8 mb-3">
                    <h5 class="card-title fw-bold">רשימה</h5>
                    <hr />

                    @foreach (var donation in MauiProgram.Synagogue.Donations ?? Enumerable.Empty<Donation>())
                    {
                        <div class="border rounded p-3 mb-2">
                            <div class="row text-center">
                                <div class="col-md-3"><b>שם:</b> @donation.Name</div>
                                <div class="col-md-2"><b>תרומה:</b> @donation.Dontation</div>
                                <div class="col-md-2"><b>שולם:</b> @donation.Paid</div>
                                <div class="col-md-3"><b>נשאר:</b> @(donation.Dontation - donation.Paid)</div>
                                <div class="col-md-2">
                                    <button class="btn btn-danger btn-sm"
                                            @onclick="async x => await DatabaseUtility.RemoveFromList(MauiProgram.Synagogue.Donations, donation)">
                                        הסר
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</form>

@code {
    string? name;
    int donation = 0;
    int paid = 0;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        MauiProgram.CurrentPage = null;
        MauiProgram.Synagogue.Donations ??= new();
    }

    public async Task Add()
    {
        MauiProgram.Synagogue.Donations?.Add(new Donation() { Name = name, Dontation = donation, Paid = paid });
        name = null;
        donation = 0;
        paid = 0;
        await DatabaseUtility.SaveAll();
    }

    public async Task RemoveFromList(int? i)
    {
        if (i.HasValue)
        {
            MauiProgram.Synagogue.Donations?.RemoveAt(i.Value);
            await DatabaseUtility.SaveAll();
        }
    }
}