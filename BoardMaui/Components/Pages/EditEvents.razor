@using BoardMaui;
@using BoardMaui.Extensions
@using BoardMaui.Models;
@inject DatabaseUtility DatabaseUtility;
@page "/editevents"
<style>
	* {
		opacity: 1 !important;
	}
</style>

<form class="container my-4">
    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="content-card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title fw-bold">עורך אירועים</h5>
                    <hr />

                    <div class="mb-3">
                        <label class="form-label">כותרת:</label>
                        <input type="text" class="form-control" @bind="title" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">ימים:</label>
                        <input type="text" class="form-control" @bind="day" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">שעה:</label>
                        <input type="time" class="form-control" @bind="time" />
                    </div>

                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" @bind="expired" id="expiredCheck" />
                        <label class="form-check-label" for="expiredCheck">אירוע זמני</label>
                    </div>

                    @if (expired)
                    {
                        <div class="mb-3">
                            <label class="form-label">תאריך תפוגה:</label>
                            <input type="date" class="form-control" @bind="expirationdate" />
                        </div>
                    }

                    <button type="reset" class="btn btn-primary w-100" @onclick="Add">הוסף</button>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-3">
            <div class="content-card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title fw-bold">רשימה</h5>
                    <hr />

                    @foreach (var eventItem in MauiProgram.Synagogue.Events ?? Enumerable.Empty<Event>())
                    {
                        <div class="border rounded p-3 mb-3">
                            <div class="row text-center">
                                <div class="col-md-3"><b>כותרת:</b> @eventItem.Title</div>
                                <div class="col-md-3"><b>ימים:</b> @eventItem.Day</div>
                                <div class="col-md-2"><b>שעה:</b> @eventItem.Time</div>
                                <div class="col-md-2"><b>תאריך תפוגה:</b> @eventItem.ExpirationDate</div>
                                <div class="col-md-2">
                                    <button class="btn btn-danger btn-sm"
                                            @onclick="async x => await DatabaseUtility.RemoveFromList(MauiProgram.Synagogue.Events, eventItem)">
                                        הסר
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</form>


@code {
	string? title;
	string? day;
	TimeOnly? time;
	DateOnly? expirationdate;
	bool expired = false;

	protected override void OnInitialized()
	{
		base.OnInitialized();
		MauiProgram.CurrentPage = null;
		MauiProgram.Synagogue.Events ??= new();
	}


	public async Task Add()
	{
		if (!string.IsNullOrWhiteSpace(title) && !string.IsNullOrWhiteSpace(day))
		{
			MauiProgram.Synagogue.Events?.Add(new Event() { Title = title, Day = day, Time = time, ExpirationDate = expirationdate });
			title = null;
			day = null;
			time = null;
			expirationdate = null;
			expired = false;
			await DatabaseUtility.SaveAll();
		}
	}

	public async Task RemoveFromList(int? i)
	{
		if (i.HasValue)
		{

			MauiProgram.Synagogue.Events?.RemoveAt(i.Value);
			await DatabaseUtility.SaveAll();
		}
	}
}