@using System.Text.Json;
@using BoardMaui;
@using BoardMaui.Extensions
@using BoardMaui.Models;
;
@inject DatabaseUtility DatabaseUtility;
@page "/editevents"
<style>
	* {
		opacity: 1 !important;
	}
</style>


<form>
	<table class="w-100 body2">
		<tr style="height: 60vmin;">
			<td valign="top" class="rounded-4 shadow">
				<table class="w-100">
					<tr>
						<td width="33%" valign="top">
							<p class="minititle">
								<b>עורך אירועים</b>
							</p>
							<hr />
							<table class="w-100">
								<tr>
									<td class="w-25">כותרת:</td>
									<td width="75%">
										<input type="text" @bind="title" />
									</td>
								</tr>
								<tr>
									<td class="w-25">ימים:</td>
									<td width="75%">
										<input type="text" @bind="day" />
									</td>
								</tr>
								<tr>
									<td class="w-25">שעה:</td>
									<td width="75%">
										<input type="time" @bind="time" />
									</td>
								</tr>
								<tr>
									<td class="w-25">אירוע זמני:</td>
									<td width="75%">
										<input type="checkbox" @bind="expired">
									</td>
								</tr>
								@if (expired)
								{
									<tr>
										<td width="33%">תאריך תפוגה:</td>
										<td class="w-66">
											<input type="date" @bind="expirationdate" />
										</td>
									</tr>
								}
								<tr>
									<td colspan="2">
										<input value="הוסף" type="reset" @onclick="Add" />
									</td>
								</tr>
							</table>
						</td>
						<td class="w-66" valign="top">
							<p class="minititle">
								<b>רשימה</b>
							</p>
							<hr />
							@foreach (var eventItem in MauiProgram.Synagogue.Events ?? Enumerable.Empty<Event>())
							{
								<table class="w-100">
									<tr>
										<td width="20%">כותרת: @eventItem.Title</td>
										<td width="20%">ימים: @eventItem.Day</td>
										<td width="20%">
											שעה:
											@eventItem.Time
										</td>
										<td width="20%">תאריך תפוגה: @eventItem.ExpirationDate</td>
										<td width="20%">
											<input value="הסר" type="button" @onclick="async x => await DatabaseUtility.RemoveFromList(MauiProgram.Synagogue.Events, eventItem)" />
										</td>
									</tr>
								</table>
								<hr />
							}
						</td>
					</tr>
				</table>
			</td>
		</tr>
	</table>
</form>

@code {
	string? title;
	string? day;
	TimeOnly? time;
	DateOnly? expirationdate;
	bool expired = false;

	protected override void OnInitialized()
	{
		base.OnInitialized();
		MauiProgram.CurrentPage = null;
		MauiProgram.Synagogue.Events ??= new();
	}


	public async Task Add()
	{
		if (!string.IsNullOrWhiteSpace(title) && !string.IsNullOrWhiteSpace(day))
		{
			MauiProgram.Synagogue.Events?.Add(new Event() { Title = title, Day = day, Time = time, ExpirationDate = expirationdate });
			title = null;
			day = null;
			time = null;
			expirationdate = null;
			expired = false;
			await DatabaseUtility.SaveAll();
		}
	}

	public async Task RemoveFromList(int? i)
	{
		if (i.HasValue)
		{

			MauiProgram.Synagogue.Events?.RemoveAt(i.Value);
			await DatabaseUtility.SaveAll();
		}
	}
}