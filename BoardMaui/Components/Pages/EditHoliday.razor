@using BoardMaui.Extensions
@using BoardMaui.Models;

@inject DatabaseUtility DatabaseUtility;
@inject AutoNavigation AutoNavigation;
@page "/editholiday"

<style>
	* {
		opacity: 1 !important;
	}
</style>
<form class="container my-4">
    <div class="content-card shadow-sm">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5 class="card-title fw-bold">עורך ימים מיוחדים</h5>
                    <hr />
                    <div class="mb-3">
                        <label class="form-label">שם יום</label>
                        <div class="input-group">
                            <input type="text" class="form-control" @bind="MauiProgram.Synagogue.Settings.CurrentHoliday" />
                            <button type="button" class="btn btn-outline-primary" @onclick="DatabaseUtility.SaveAll">שמור</button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">שם אירוע/תפילה</label>
                        <input type="text" class="form-control" @bind="holidayEvent" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">זמן</label>
                        <input type="time" class="form-control" @bind="holidayEventTime" />
                    </div>

                    <button type="reset" class="btn btn-primary w-100" @onclick="Add">הוסף</button>
                </div>

                <div class="col-md-8 mb-3">
                    <h5 class="card-title fw-bold">רשימה</h5>
                    <hr />
                    @foreach (var prayer in MauiProgram.Synagogue.HolidayPrays ?? [])
                    {
                        <div class="border rounded p-3 mb-2">
                            <div class="row">
                                <div class="col-md-5">@prayer.Title</div>
                                <div class="col-md-4">@prayer.Time</div>
                                <div class="col-md-3 text-end">
                                    <button class="btn btn-danger btn-sm"
                                            @onclick="async x => await DatabaseUtility.RemoveFromList(MauiProgram.Synagogue.HolidayPrays, prayer)">
                                        הסר
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</form>

@code
{
	string? holidayEvent;
	TimeOnly? holidayEventTime;
	protected override void OnInitialized()
	{
		base.OnInitialized();
		MauiProgram.CurrentPage = null;
		MauiProgram.Synagogue.HolidayPrays ??= new();
	}

	public async Task RemoveFromList(int? i)
	{
		if (i.HasValue)
		{
			MauiProgram.Synagogue.HolidayPrays?.RemoveAt(i.Value);
			await DatabaseUtility.SaveAll();
		}
	}

	public async Task Add()
	{
		MauiProgram.Synagogue.HolidayPrays?.Add(new Pray() { Title = holidayEvent, Time = holidayEventTime, Dynamic = false, Shabbat = false });
		holidayEvent = null;
		holidayEventTime = null;
		await DatabaseUtility.SaveAll();
	}
}