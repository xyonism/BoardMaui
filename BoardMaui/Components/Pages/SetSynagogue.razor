@using System.Text.Json
@using BoardMaui.Extensions
@using QRCoder
@inject IJSRuntime JS

@inject DatabaseUtility DatabaseUtility
@inject NavigationManager NavigationManager
@page "/setsynagogue"
<style>
	*
	{
		opacity: 1 !important;
	}
</style>
<div class="container my-4">
	<div class="content-card shadow-sm">
		<div class="card-body">
			<h5 class="card-title fw-bold">הגדרת בית כנסת</h5>
			<hr />
			<div class="mb-3">
				<label class="form-label">מזהה בית כנסת:</label>
				<input class="form-control text-center"
					   style="direction: ltr !important; font-family: system-ui !important;"
					   type="text"
					   @bind="MauiProgram.Synagogue.Guid" />
			</div>
			<div class="d-flex flex-wrap gap-2 mb-3">
				<button class="btn btn-success" @onclick="Save">שמור הכל</button>
				<button class="btn btn-outline-primary" @onclick="GenerateQrCode">צור QR Code</button>
			</div>

			@if (!string.IsNullOrEmpty(qrImageData))
			{
				<div class="mb-3">
					<img src="@qrImageData" class="mt-3 img-fluid" style="max-width: 300px;" />
				</div>
			}

			<div class="mb-3">
				<label class="form-label d-block">סריקת QR:</label>
				<div id="reader" style="width: 300px;" class="border rounded p-2 mb-2"></div>
				<button type="button" class="btn btn-outline-secondary" @onclick="StartScan">סרוק QR</button>
			</div>
		</div>
	</div>
</div>


@code {
	string qrImageData;


	async Task GenerateQrCode()
	{
		var generator = new QRCodeGenerator();
		var data = generator.CreateQrCode(MauiProgram.Synagogue.Guid, QRCodeGenerator.ECCLevel.Q);
		var qrCode = new PngByteQRCode(data);
		var pngBytes = qrCode.GetGraphic(20);
		qrImageData = $"data:image/png;base64,{Convert.ToBase64String(pngBytes)}";
	}

	async Task StartScan()
	{
		await JS.InvokeVoidAsync("startQrScanner", DotNetObjectReference.Create(this));
	}

	[JSInvokable]
	public Task SetScanResult(string result)
	{
		MauiProgram.Synagogue.Guid = result;
		return Task.CompletedTask;
	}
	protected override void OnInitialized()
	{
		base.OnInitialized();
		MauiProgram.CurrentPage = null;
	}

	public async Task Save()
	{
		if (!string.IsNullOrEmpty(MauiProgram.Synagogue.Guid))
		{
			Preferences.Set("Synagogue.Guid", MauiProgram.Synagogue.Guid);
			await MauiProgram.LoadSynagogueDataAsync();
			NavigationManager.Refresh(true);
		}
	}
}
