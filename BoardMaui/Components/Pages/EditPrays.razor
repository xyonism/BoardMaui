@using System.Text.Json;
@using System.Text.Json.Serialization;
@using BoardMaui.Extensions
@using BoardMaui.Models
@page "/editprays"
@inject NavigationManager NavigationManager
@inject DatabaseUtility DatabaseUtility
<style>
	* {
		opacity: 1 !important;
	}
</style>
<form class="container my-4">
    <div class="content-card shadow-sm">
        <div class="card-body">

            <!-- שחרית -->
            <h5 class="card-title fw-bold text-center">עורך תפילות</h5>
            <hr />
            <div class="mb-4">
                <h6 class="fw-bold">שחרית</h6>
                <hr />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="mb-3">
                            <label class="form-label">כותרת</label>
                            <input type="text" class="form-control" @bind="NewShaharitPray.Title" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">יום בשבוע</label>
                            <select class="form-select" @bind="NewShaharitPray.DayOfWeek">
                                <option value="" selected>בחר יום</option>
                                @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                                {
                                    var dayName = culture.DateTimeFormat.GetDayName(day);
                                    <option value="@dayName">@dayName</option>
                                }
                            </select>
                        </div>
                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" @bind="NewShaharitPray.Dynamic" id="shaharitDynamic" />
                            <label class="form-check-label" for="shaharitDynamic">זמן משתנה אוטומטית</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">זמן</label>
                            <input type="time" class="form-control" @bind="NewShaharitPray.Time" />
                            @if (NewShaharitPray.Dynamic)
                            {
                                <small class="text-muted d-block mt-1">דקות מהנץ</small>
                            }
                        </div>
                        <button type="reset" class="btn btn-primary w-100" @onclick="AddShaharit">הוסף</button>
                    </div>

                    <div class="col-md-6 mb-3">
                        @foreach (var Pray in MauiProgram.Synagogue.ShaharitPrays ?? [])
                        {
                            <div class="border rounded p-3 mb-2">
                                <div class="row">
                                    <div class="col-md-4 fw-bold">@Pray.Title</div>
                                    <div class="col-md-4">
                                        @if (Pray.Dynamic)
                                        {
                                            try
                                            {
                                                @(TimeOnly.FromDateTime(calendar.GetSunrise()).Add(Pray.Time.GetValueOrDefault().ToTimeSpan()))
                                                <br />
                                                <small class="text-muted">זמן משתנה אוטומטית</small>
                                            }
                                            catch
                                            {
                                                @TimeOnly.FromDateTime(calendar.GetSunrise())
                                            }
                                        }
                                        else
                                        {
                                            @Pray.Time
                                        }
                                    </div>
                                    <div class="col-md-2">
                                        <span>@Pray.DayOfWeek</span>
                                    </div>
                                    <div class="col-md-2 text-end">
                                        <button class="btn btn-danger btn-sm"
                                                @onclick="async x => await DatabaseUtility.RemoveFromList(MauiProgram.Synagogue.ShaharitPrays, Pray)">
                                            הסר
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <hr />

            <!-- מנחה -->
            <div class="mb-4">
                <h6 class="fw-bold">מנחה</h6>
                <hr />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="mb-3">
                            <label class="form-label">כותרת</label>
                            <input type="text" class="form-control" @bind="NewMinhaPray.Title" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">יום בשבוע</label>
                            <select class="form-select" @bind="NewMinhaPray.DayOfWeek">
                                <option value="" selected>בחר יום</option>
                                @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                                {
                                    var dayName = culture.DateTimeFormat.GetDayName(day);
                                    <option value="@dayName">@dayName</option>
                                }
                            </select>
                        </div>
                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" @bind="NewMinhaPray.Dynamic" id="minhaDynamic" />
                            <label class="form-check-label" for="minhaDynamic">זמן משתנה אוטומטית</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">זמן</label>
                            <input type="time" class="form-control" @bind="NewMinhaPray.Time" />
                            @if (NewMinhaPray.Dynamic)
                            {
                                <small class="text-muted d-block mt-1">מהשקיעה</small>
                            }
                        </div>
                        <button type="reset" class="btn btn-primary w-100" @onclick="AddMinha">הוסף</button>
                    </div>

                    <div class="col-md-6 mb-3">
                        @foreach (var Pray in MauiProgram.Synagogue.MinhaPrays ?? [])
                        {
                            <div class="border rounded p-3 mb-2">
                                <div class="row">
                                    <div class="col-md-4 fw-bold">@Pray.Title</div>
                                    <div class="col-md-4">
                                        @if (Pray.Dynamic)
                                        {
                                            try
                                            {
                                                @(TimeOnly.FromDateTime(calendar.GetSunset()).Add(Pray.Time.GetValueOrDefault().ToTimeSpan()))
                                                <br />
                                                <small class="text-muted">זמן משתנה אוטומטית</small>
                                            }
                                            catch
                                            {
                                                @TimeOnly.FromDateTime(calendar.GetSunset())
                                            }
                                        }
                                        else
                                        {
                                            @Pray.Time
                                        }
                                    </div>
                                    <div class="col-md-2">
                                        <span>@Pray.DayOfWeek</span>
                                    </div>
                                    <div class="col-md-2 text-end">
                                        <button class="btn btn-danger btn-sm"
                                                @onclick="async x => await DatabaseUtility.RemoveFromList(MauiProgram.Synagogue.MinhaPrays, Pray)">
                                            הסר
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <hr />

            <!-- ערבית -->
            <div class="mb-4">
                <h6 class="fw-bold">ערבית</h6>
                <hr />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="mb-3">
                            <label class="form-label">כותרת</label>
                            <input type="text" class="form-control" @bind="NewArvitPray.Title" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">יום בשבוע</label>
                            <select class="form-select" @bind="NewArvitPray.DayOfWeek">
                                <option value="" selected>בחר יום</option>
                                @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                                {
                                    var dayName = culture.DateTimeFormat.GetDayName(day);
                                    <option value="@dayName">@dayName</option>
                                }
                            </select>
                        </div>
                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" @bind="NewArvitPray.Dynamic" id="arvitDynamic" />
                            <label class="form-check-label" for="arvitDynamic">זמן משתנה אוטומטית</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">זמן</label>
                            <input type="time" class="form-control" @bind="NewArvitPray.Time" />
                            @if (NewArvitPray.Dynamic)
                            {
                                <small class="text-muted d-block mt-1">מצאת הכוכבים</small>
                            }
                        </div>
                        <button type="reset" class="btn btn-primary w-100" @onclick="AddArvit">הוסף</button>
                    </div>

                    <div class="col-md-6 mb-3">
                        @foreach (var Pray in MauiProgram.Synagogue.ArvitPrays ?? [])
                        {
                            <div class="border rounded p-3 mb-2">
                                <div class="row">
                                    <div class="col-md-4 fw-bold">@Pray.Title</div>
                                    <div class="col-md-4">
                                        @if (Pray.Dynamic)
                                        {
                                            try
                                            {
                                                @(TimeOnly.FromDateTime(calendar.GetSunset()).AddMinutes(13.5).Add(Pray.Time.GetValueOrDefault().ToTimeSpan()))
                                                <br />
                                                <small class="text-muted">זמן משתנה אוטומטית</small>
                                            }
                                            catch
                                            {
                                                @TimeOnly.FromDateTime(calendar.GetSunset()).AddMinutes(13.5)
                                            }
                                        }
                                        else
                                        {
                                            @Pray.Time
                                        }
                                    </div>
                                    <div class="col-md-2">
                                        <span>@Pray.DayOfWeek</span>
                                    </div>
                                    <div class="col-md-2 text-end">
                                        <button class="btn btn-danger btn-sm"
                                                @onclick="async x => await DatabaseUtility.RemoveFromList(MauiProgram.Synagogue.ArvitPrays, Pray)">
                                            הסר
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</form>
@code
{

	public System.Globalization.CultureInfo culture { get; set; } = new System.Globalization.CultureInfo("he-IL");
	public Pray NewShaharitPray { get; set; } = new Pray();
	public Pray NewMinhaPray { get; set; } = new Pray();
	public Pray NewArvitPray { get; set; } = new Pray();
	public ComplexZmanimCalendar calendar = new ComplexZmanimCalendar(DateTime.Today, new GeoLocation("Jerusalem, IL", MauiProgram.Synagogue.Settings.Latitude, MauiProgram.Synagogue.Settings.Longitude, 0, new OlsonTimeZone("Asia/Jerusalem")))
	{
		AstronomicalCalculator = new BoardMaui.Extensions.Calculator.SunTimesCalculator()
	};
	protected override void OnInitialized()
	{
		base.OnInitialized();
		MauiProgram.CurrentPage = null;
		MauiProgram.Synagogue.ShaharitPrays ??= new();
		MauiProgram.Synagogue.MinhaPrays ??= new();
		MauiProgram.Synagogue.ArvitPrays ??= new();
	}



	public async Task AddShaharit()
	{
		NewShaharitPray.Shabbat = culture.DateTimeFormat.GetDayName(Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>().Last()) == NewShaharitPray.DayOfWeek;

		MauiProgram.Synagogue.ShaharitPrays?.Add(NewShaharitPray);
		NewShaharitPray = new();
		await DatabaseUtility.SaveAll();
	}
	public async Task AddMinha()
	{
		NewMinhaPray.Shabbat = culture.DateTimeFormat.GetDayName(Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>().Last()) == NewMinhaPray.DayOfWeek;

		MauiProgram.Synagogue.MinhaPrays?.Add(NewMinhaPray);
		NewMinhaPray = new();
		await DatabaseUtility.SaveAll();
	}
	public async Task AddArvit()
	{
		NewArvitPray.Shabbat = culture.DateTimeFormat.GetDayName(Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>().Last()) == NewArvitPray.DayOfWeek;

		MauiProgram.Synagogue.ArvitPrays?.Add(NewArvitPray);
		NewArvitPray = new();
		await DatabaseUtility.SaveAll();
	}

	public async Task RemoveShaharitFromList(int? i)
	{
		if (i.HasValue)
		{
			MauiProgram.Synagogue.ShaharitPrays?.RemoveAt(i.Value);
			await DatabaseUtility.SaveAll();
		}


	}
	public async Task RemoveMinhaFromList(int? i)
	{
		if (i.HasValue)
		{
			MauiProgram.Synagogue.MinhaPrays?.RemoveAt(i.Value);
			await DatabaseUtility.SaveAll();
		}

	}
	public async Task RemoveArvitFromList(int? i)
	{
		if (i.HasValue)
		{
			MauiProgram.Synagogue.ArvitPrays?.RemoveAt(i.Value);
			await DatabaseUtility.SaveAll();
		}

	}
}