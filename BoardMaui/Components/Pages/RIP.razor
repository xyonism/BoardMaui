@using System.Text.Json;
@using BoardMaui.Extensions
@using BoardMaui.Models

@inject NavigationManager NavigationManager
@inject AutoNavigation AutoNavigation
@page "/rip"

<style>
	.title {
		font-size: @((3.75 * FontSize) + "vmin !important");
	}

	.minititle {
		font-size: @((2.75 * FontSize) + "vmin !important");
	}

	.customtext {
		font-size: @((1.75 * FontSize) + "vmin !important");
	}

	.hugetext {
		font-size: @((7.5 * FontSize) + "vmin !important");
	}

	.body > tr > td {
		font-size: @((2.5 * FontSize) + "vmin");
	}

	.body2 > tr > td {
		font-size: @((2.25 * FontSize) + "vmin");
	}

</style>




<table class="w-100 m-auto" style="border-spacing: 3vmin;">
	<tr>
		<td class="rounded-4 shadow content-card" colspan="6">
			<p class="minititle">
				<b>לעילוי נשמת</b>
			</p>
		</td>
	</tr>
	@for (int j = 0; j < 6; j++)
	{
		<tr class="body">

			@for (int i = 0; i < 6; i++)
			{
				@if (j * 6 + i < MauiProgram.Synagogue.RIPs?.Count)
				{
					<td class="rounded-4 customtext" style="width: 10%; border-radius: 10px;">
						@MauiProgram.Synagogue.RIPs[j * 6 + i].Name
						<br />
						@MauiProgram.Synagogue.RIPs[j * 6 + i].Date
					</td>
				}
			}
		</tr>
	}
</table>

@code
{
	public double FontSize = 1 + MauiProgram.Synagogue.Settings.FontSize[nameof(RIP)] * 0.1;
	protected override void OnInitialized()
	{
		base.OnInitialized();
		MauiProgram.Synagogue.RIPs ??= new();
	}
	Person person = new Person();

	protected override async Task OnAfterRenderAsync(bool first)
	{
		await base.OnAfterRenderAsync(first);
		if (first)
			await AutoNavigation.AutoNavigateAsync(MauiProgram.Synagogue.Settings.ShowRIP, "rip", "/donations");
	}
	
}