                    <!-- base -->
                    <path d="M11 26 h16"></path>
                    <path d="M19 26 v-6"></path>
                    <!-- trunk -->
                    <path d="M19 20 v-14"></path>
                    <!-- arms -->
                    <path d="M19 10 Q14 10 14 6"></path>
                    <path d="M19 10 Q24 10 24 6"></path>
                    <path d="M19 12 Q12 12 12 6"></path>
                    <path d="M19 12 Q26 12 26 6"></path>
                    <path d="M19 14 Q10 14 10 6"></path>
                    <path d="M19 14 Q28 14 28 6"></path>
                    <!-- flames -->
