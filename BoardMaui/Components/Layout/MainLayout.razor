@code {

    public string? Day;
    public string? MonthDay;

    protected override void OnParametersSet()
    {
        DeviceDisplay.Current.KeepScreenOn = true;

        System.Globalization.CultureInfo culture =
            new System.Globalization.CultureInfo("he-IL");

        // Determine current Hebrew day name, switching to "ליל" after sunset + 13.5 min
        try
        {
            bool pastSunset = TimeOnly.FromDateTime(
                DateTime.Parse($"{MauiProgram.Calendar?.GetSunset()}").AddMinutes(13.5)
            ) < TimeOnly.FromDateTime(DateTime.UtcNow);

            Day = pastSunset
                ? culture.DateTimeFormat.GetDayName(DateTime.Today.AddDays(1).DayOfWeek)
                                        .Replace("יום", "ליל")
                : culture.DateTimeFormat.GetDayName(DateTime.Today.DayOfWeek);
        }
        catch
        {
            Day = culture.DateTimeFormat.GetDayName(DateTime.Today.DayOfWeek);
        }

        // Hebrew calendar date
        culture.DateTimeFormat.Calendar = new HebrewCalendar();
        MonthDay = DateTime.Now.ToString(culture.DateTimeFormat.MonthDayPattern, culture);
    }

}
