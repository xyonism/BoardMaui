                    <circle cx="12" cy="5" r="1.4" fill="#c9a227" stroke="none"></circle>
                    <circle cx="14" cy="5" r="1.4" fill="#c9a227" stroke="none"></circle>
                    <circle cx="19" cy="4" r="1.6" fill="#c9a227" stroke="none"></circle>
                    <circle cx="24" cy="5" r="1.4" fill="#c9a227" stroke="none"></circle>
                    <circle cx="26" cy="5" r="1.4" fill="#c9a227" stroke="none"></circle>
                    <circle cx="28" cy="5" r="1.4" fill="#c9a227" stroke="none"></circle>
