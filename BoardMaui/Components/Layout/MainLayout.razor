        <line x1="14" y1="1" x2="14" y2="27" stroke="#c9a227" stroke-width="1" opacity=".5" />
        <line x1="1" y1="14" x2="27" y2="14" stroke="#c9a227" stroke-width="1" opacity=".5" />
        <line x1="5" y1="5" x2="23" y2="23" stroke="#c9a227" stroke-width="0.8" opacity=".35" />
        <line x1="23" y1="5" x2="5" y2="23" stroke="#c9a227" stroke-width="0.8" opacity=".35" />
    </svg>

    <svg class="corner-rosette right" aria-hidden="true" viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg">
        <circle cx="14" cy="14" r="5" fill="none" stroke="#c9a227" stroke-width="1.5" />
        <line x1="14" y1="1" x2="14" y2="27" stroke="#c9a227" stroke-width="1" opacity=".5" />
        <line x1="1" y1="14" x2="27" y2="14" stroke="#c9a227" stroke-width="1" opacity=".5" />
        <line x1="5" y1="5" x2="23" y2="23" stroke="#c9a227" stroke-width="0.8" opacity=".35" />
        <line x1="23" y1="5" x2="5" y2="23" stroke="#c9a227" stroke-width="0.8" opacity=".35" />
    </svg>

