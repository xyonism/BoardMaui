    <!-- Day / Time / Hebrew Date tablets -->
    <table class="head">
        <tr>
            <td class="w-33">
                <span class="tablet-corner-tl" aria-hidden="true"></span>
                <span class="eyebrow">יום</span>
                <b>@Day</b>
            </td>

            <td class="w-33">
                <span class="tablet-corner-tl" aria-hidden="true"></span>
                <span class="eyebrow">שעה</span>
                <b>@TimeOnly.FromDateTime(DateTime.Now)</b>
            </td>

            <td class="w-33">
                <span class="tablet-corner-tl" aria-hidden="true"></span>
                <span class="eyebrow">תאריך עברי</span>
                <b>@MonthDay</b>
            </td>
        </tr>
    </table>

</header>

<main class="main-content">
    <div class="divider">
        <div class="divider-line"></div>
        <svg style="width: 2vmin; height: 2vmin" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <g fill="#c9a227">
                <polygon points="50,3 95,75 5,75"></polygon>
                <polygon points="50,97 5,25 95,25"></polygon>
            </g>
        </svg>
        <div class="divider-line"></div>
    </div>
    @Body
    <div class="divider">
        <div class="divider-line"></div>
        <svg style="width: 2vmin; height: 2vmin" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <g fill="#c9a227">
                <polygon points="50,3 95,75 5,75"></polygon>
                <polygon points="50,97 5,25 95,25"></polygon>
            </g>
        </svg>
        <div class="divider-line"></div>
    </div>
</main>

<footer>
    <table class="footer-custom text-center">
        <tr>
            @if (!String.IsNullOrEmpty(MauiProgram.Synagogue.Settings.Dedication))
            {
                <td class="w-33 dedication">
                    <b>@MauiProgram.Synagogue.Settings.Dedication</b>
                </td>
            }

            <td class="w-33" style="direction: ltr;">
                ☎️ 054‑826‑6522
            </td>

            <td class="w-33 version-label">
                Ver: @VersionTracking.Default.CurrentVersion.@VersionTracking.Default.CurrentBuild
            </td>
        </tr>
    </table>
</footer>


@code {

    public string? Day;
    public string? MonthDay;

    protected override void OnParametersSet()
    {
        DeviceDisplay.Current.KeepScreenOn = true;

        System.Globalization.CultureInfo culture =
            new System.Globalization.CultureInfo("he-IL");

        // Determine current Hebrew day name, switching to "ליל" after sunset + 13.5 min
        try
        {
            bool pastSunset = TimeOnly.FromDateTime(
                DateTime.Parse($"{MauiProgram.Calendar?.GetSunset()}").AddMinutes(13.5)
            ) < TimeOnly.FromDateTime(DateTime.Now);

            Day = pastSunset
                ? culture.DateTimeFormat.GetDayName(DateTime.Today.AddDays(1).DayOfWeek)
                                        .Replace("יום", "ליל")
                : culture.DateTimeFormat.GetDayName(DateTime.Today.DayOfWeek);
        }
        catch
        {
            Day = culture.DateTimeFormat.GetDayName(DateTime.Today.DayOfWeek);
        }

        // Hebrew calendar date
        culture.DateTimeFormat.Calendar = new HebrewCalendar();
        MonthDay = DateTime.Now.ToString("d בMMMM yyyy", culture);
    }

}
